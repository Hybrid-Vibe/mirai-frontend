{
  "name": "mirai-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "security:scan": "bash ./scripts/security-scan.sh",
    "security:scan:gitleaks": "gitleaks detect --source . --no-git --redact --exit-code 1 --config .gitleaks.toml",
    "security:scan:trufflehog": "trufflehog filesystem . --fail --exclude-paths .trufflehogignore",
    "prepush:check": "npm run lint && npm run security:scan"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@google/generative-ai": "^0.24.1",
    "@google/model-viewer": "^4.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.105.1",
    "axios": "^1.15.2",
    "canvas": "^3.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "konva": "^10.2.5",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-konva": "^19.2.3",
    "resend": "^6.12.2",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "use-image": "^1.1.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "@google/model-viewer": {
      "three": "$three"
    }
  }
}
