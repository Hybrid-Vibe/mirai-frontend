# ==========================================================
# MIRAI - .gitignore (Next.js/Node.js, production-ready)
# Keep repo clean, secure, and deterministic for CI/CD.
# ==========================================================

# ------------------------------
# OS / editor junk
# ------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# IDEs
.idea/
.fleet/
*.swp
*.swo
*~

# VS Code local workspace state (machine-specific)
.vscode/*.code-workspace
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json

# ------------------------------
# Dependencies
# ------------------------------
node_modules/

# Yarn PnP / cache
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ------------------------------
# Build / framework outputs
# ------------------------------
.next/
out/
build/
dist/

# Turbopack / turbo cache
.turbo/

# Static export / generated artifacts
storybook-static/

# ------------------------------
# Test / coverage artifacts
# ------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# ------------------------------
# TypeScript / lint caches
# ------------------------------
*.tsbuildinfo
.eslintcache

# ------------------------------
# Logs / runtime files
# ------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

*.pid
*.seed
*.pid.lock

# ------------------------------
# Environment / secrets
# ------------------------------
# Never commit secrets. Keep one template file for onboarding.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Optional: if team uses broader env naming, keep these ignored too.
.env.*
!.env.example

# direnv
.envrc
.direnv/

# Common secret file patterns
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks

# ------------------------------
# Deployment platforms
# ------------------------------
.vercel/

# ------------------------------
# Next.js generated type helper
# ------------------------------
next-env.d.ts

# ------------------------------
# Internal instruction docs (do not push)
# ------------------------------
AGENTS.md
SKILLS.md
PROJECT-INSTRUCTION.md

# ------------------------------
# Markdown policy: block all .md except root README
# ------------------------------
*.md
!README.md
