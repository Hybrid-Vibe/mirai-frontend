# ==========================================================
# MIRAI - Environment Template
# Copy this file to .env.local and fill real values.
# Never commit real credentials or production secrets.
# ==========================================================

# ------------------------------
# App / runtime
# ------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=MIRAI
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=vi
NEXT_PUBLIC_API_URL=http://localhost:5236

# Feature flags (public-safe values only)
NEXT_PUBLIC_ENABLE_AR=true
NEXT_PUBLIC_ENABLE_EXPERIMENTAL_EDITOR=false

# ------------------------------
# AI Provider (server-side)
# ------------------------------
# Keep this key server-only. Never expose through NEXT_PUBLIC_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------
# Database / backend (future phases)
# ------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ------------------------------
# Auth / session (NextAuth v5 / Auth.js)
# Generate AUTH_SECRET with: openssl rand -base64 32
# ------------------------------
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------
# Payments (future phases)
# ------------------------------
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay/callback

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------
# File storage / media (optional)
# ------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------
# Shipping — GHN (Giao Hàng Nhanh)
# Docs: https://api.ghn.vn/home/docs/detail
# ------------------------------
GHN_TOKEN=
GHN_SHOP_ID=
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api

# ------------------------------
# Email — Resend
# Docs: https://resend.com/docs
# Free: 3,000 emails/month
# ------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=MIRAI <noreply@mirai.vn>

# ------------------------------
# Observability (optional)
# ------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

