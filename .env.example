# ==========================================================
# MIRAI - Environment Template
# Copy this file to .env.local and fill real values.
# Never commit real credentials or production secrets.
# ==========================================================

# ------------------------------
# App / runtime
# ------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=MIRAI
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=vi
NEXT_PUBLIC_API_URL=http://mirai.runasp.net

# Feature flags (public-safe values only)
NEXT_PUBLIC_ENABLE_AR=true
NEXT_PUBLIC_ENABLE_EXPERIMENTAL_EDITOR=false

# ------------------------------
# AI generation
# ------------------------------
# AI image generation is owned by the .NET backend via NEXT_PUBLIC_API_URL.
# Keep provider secrets such as Replicate/Groq tokens in backend config only.

# ------------------------------
# Supabase Auth
# ------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ------------------------------
# Auth / session (NextAuth v5 / Auth.js)
# Generate AUTH_SECRET with: openssl rand -base64 32
# ------------------------------
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------
# Payments (future phases)
# ------------------------------
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=
VNPAY_RETURN_URL=http://localhost:3000/api/payment/vnpay/callback

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------
# File storage / media (optional)
# ------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------
# Shipping — GHN (Giao Hàng Nhanh)
# Docs: https://api.ghn.vn/home/docs/detail
# ------------------------------
GHN_TOKEN=
GHN_SHOP_ID=
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api

# ------------------------------
# Email — Resend
# Docs: https://resend.com/docs
# Free: 3,000 emails/month
# ------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=MIRAI <noreply@mirai.vn>

# ------------------------------
# Observability (optional)
# ------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
