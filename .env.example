# ==========================================================
# MIRAI - Environment Template
# Copy this file to .env.local and fill real values.
# Never commit real credentials or production secrets.
# ==========================================================

# ------------------------------
# App / runtime
# ------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=MIRAI
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=vi

# Feature flags (public-safe values only)
NEXT_PUBLIC_ENABLE_AR=true
NEXT_PUBLIC_ENABLE_EXPERIMENTAL_EDITOR=false

# ------------------------------
# AI Provider (server-side)
# ------------------------------
# Keep this key server-only. Never expose through NEXT_PUBLIC_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------
# Database / backend (future phases)
# ------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ------------------------------
# Auth / session (future phases)
# ------------------------------
AUTH_SECRET=
JWT_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ------------------------------
# Payments (future phases)
# ------------------------------
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=

VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay/callback

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------
# File storage / media (optional)
# ------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------
# Email / notifications (optional)
# ------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ------------------------------
# Observability (optional)
# ------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
